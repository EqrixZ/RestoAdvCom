<section class="card page-head">
    <div>
        <h2>การจองของฉัน</h2>
        <p class="muted">ตรวจสอบสถานะและยกเลิกเฉพาะรายการที่ยังยืนยันอยู่</p>
    </div>
</section>

<section class="card">
    <div class="table-wrap">
        <table class="data-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>โต๊ะ</th>
                    <th>โซน</th>
                    <th>จำนวนลูกค้า</th>
                    <th>เริ่ม</th>
                    <th>สิ้นสุด</th>
                    <th>สถานะ</th>
                    <th>การจัดการ</th>
                </tr>
            </thead>
            <tbody>
                <% if (!reservations.length) { %>
                    <tr><td colspan="8" class="empty">ไม่พบรายการจอง</td></tr>
                <% } else { %>
                    <% reservations.forEach((item) => { %>
                        <tr>
                            <td><%= item.id %></td>
                            <td><%= item.table_number %></td>
                            <td><%= item.zone_name %></td>
                            <td><%= item.party_size || 1 %></td>
                            <td><%= item.booking_time %></td>
                            <td><%= item.end_time %></td>
                            <td>
                                <span class="badge <%= item.status === 'Confirmed' ? 'info' : (item.status === 'Completed' ? 'ok' : 'warn') %>">
                                    <%= item.status === "Confirmed" ? "ยืนยันแล้ว" : (item.status === "Completed" ? "เสร็จสิ้น" : "ยกเลิกแล้ว") %>
                                </span>
                            </td>
                            <td>
                                <% if (item.status === "Confirmed") { %>
                                    <form method="post" action="/user/reservations/<%= item.id %>/cancel" onsubmit="return confirm('ยืนยันการยกเลิกใช่หรือไม่?')">
                                        <input type="hidden" name="_method" value="PUT">
                                        <button class="btn btn-delete" type="submit">ยกเลิกการจอง</button>
                                    </form>
                                <% } else { %>
                                    <span class="muted">ไม่มี</span>
                                <% } %>
                            </td>
                        </tr>
                    <% }) %>
                <% } %>
            </tbody>
        </table>
    </div>
</section>
