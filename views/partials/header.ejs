<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RestoBook - <%= title %></title>
    <script>
        (function () {
            var saved = localStorage.getItem("restobook-theme");
            if (saved === "dark") {
                document.documentElement.setAttribute("data-theme", "dark");
            }
        })();
    </script>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <header class="topbar">
        <div class="brand">
            <h1>RestoBook</h1>
            <p>จองโต๊ะแบบเรียลไทม์ รอบละ 2 ชั่วโมง</p>
        </div>
        <nav class="nav">
            <a href="/home" class="<%= activePage === 'home' ? 'active' : '' %>">หน้าแรก</a>
            <a href="/customers" class="<%= activePage === 'customers' ? 'active' : '' %>">ลูกค้า</a>
            <a href="/zones" class="<%= activePage === 'zones' ? 'active' : '' %>">โซน</a>
            <a href="/tables" class="<%= activePage === 'tables' ? 'active' : '' %>">โต๊ะอาหาร</a>
            <a href="/reservations" class="<%= activePage === 'reservations' ? 'active' : '' %>">การจอง</a>
            <a href="/reports/daily-table-usage" class="<%= activePage === 'reports' ? 'active' : '' %>">รายงาน</a>
            <a href="/login/user">เข้าสู่ระบบผู้ใช้</a>
        </nav>
        <div class="inline">
            <button type="button" id="theme-toggle" class="btn btn-cancel theme-toggle">โหมดมืด</button>
            <form method="post" action="/logout">
                <button type="submit" class="btn btn-delete">ออกจากระบบ</button>
            </form>
        </div>
    </header>
