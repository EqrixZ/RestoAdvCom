<section class="card form-card">
<h2>โซนใหม่</h2>
<form class="form" method="post" action="/zones">
<label>ชื่อโซน<input type="text" name="zone_name" required maxlength="100"></label>
<label>รายละเอียด<textarea name="description" maxlength="250"></textarea></label>
<label>ค่าบริการเพิ่มเติม<input type="number" name="extra_charge" min="0" step="0.01" value="0"></label>
<div class="inline"><button type="submit" class="btn btn-add">บันทึก</button><a href="/zones" class="btn btn-cancel">ยกเลิก</a></div>
</form>
</section>