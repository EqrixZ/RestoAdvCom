<section class="grid two-cols">
    <article class="card">
        <h2>เพิ่มโซน</h2>
        <form method="post" action="/zones" class="form">
            <label>
                ชื่อโซน
                <input type="text" name="zone_name" placeholder="Indoor / Garden" required>
            </label>
            <label>
                รายละเอียด
                <textarea name="description" rows="4" placeholder="รายละเอียดโซน"></textarea>
            </label>
            <label>
                ค่าบริการเพิ่มเติม (บาท)
                <input type="number" name="extra_charge" min="0" step="0.01" value="0">
            </label>
            <button type="submit" class="btn btn-add">เพิ่มโซน</button>
        </form>
    </article>

    <article class="card">
        <h2>โซน</h2>
        <div class="table-wrap">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>ชื่อโซน</th>
                        <th>รายละเอียด</th>
                        <th>ค่าบริการเพิ่มเติม</th>
                        <th>จำนวนโต๊ะ</th>
                        <th>การจัดการ</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (!zones.length) { %>
                        <tr>
                            <td colspan="6" class="empty">ยังไม่มีโซน</td>
                        </tr>
                    <% } %>
                    <% zones.forEach((zone) => { %>
                        <tr>
                            <td><%= zone.id %></td>
                            <td><%= zone.zone_name %></td>
                            <td><%= zone.description || '-' %></td>
                            <td><%= Number(zone.extra_charge).toFixed(2) %></td>
                            <td><%= zone.table_count %></td>
                            <td>
                                <form method="post" action="/zones/<%= zone.id %>/delete" onsubmit="return confirm('ลบโซนนี้ใช่หรือไม่?')">
                                    <button type="submit" class="btn btn-delete">ลบ</button>
                                </form>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </article>
</section>
