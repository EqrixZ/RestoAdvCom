<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RestoBook - <%= title %></title>
    <script>
        (function () {
            var saved = localStorage.getItem("restobook-theme");
            if (saved === "dark") {
                document.documentElement.setAttribute("data-theme", "dark");
            }
        })();
    </script>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <header class="topbar">
        <div class="brand">
            <h1>RestoBook User</h1>
            <p>ยินดีต้อนรับ <%= auth && auth.customerName ? auth.customerName : "ผู้ใช้งาน" %></p>
        </div>
        <nav class="nav">
            <a href="/user/home" class="<%= activePage === 'user-home' ? 'active' : '' %>">โต๊ะว่างและเวลา</a>
            <a href="/user/reservations/new" class="<%= activePage === 'user-book' ? 'active' : '' %>">จองโต๊ะ</a>
            <a href="/user/reservations" class="<%= activePage === 'user-my-reservations' ? 'active' : '' %>">การจองของฉัน</a>
            <a href="/login/admin">เข้าสู่ระบบแอดมิน</a>
        </nav>
        <div class="inline">
            <button type="button" id="theme-toggle" class="btn btn-cancel theme-toggle">โหมดมืด</button>
            <form method="post" action="/logout">
                <button type="submit" class="btn btn-delete">ออกจากระบบ</button>
            </form>
        </div>
    </header>

    <main class="container">
        <% if (flashMessage) { %>
            <div class="flash flash-<%= flashType === "error" ? "error" : "success" %>">
                <%= flashMessage %>
            </div>
        <% } %>
        <%- include(content) %>
    </main>

    <%- include("../partials/footer") %>
